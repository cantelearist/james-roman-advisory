# staging lane only.
# Copy to a private local file or export these values in your shell.
# Do not commit real values.

NEXT_PUBLIC_SUPABASE_URL=
# Supabase may call this the publishable key in newer dashboards.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AUDIT_HASH_SECRET=

# Sentry error monitoring. DSNs are public ingest endpoints; auth token is secret.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional until payment testing starts. Use Stripe test mode only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
